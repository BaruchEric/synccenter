# Path to the synccenter-config repo (folders/, rules/, hosts/, imports/).
SC_CONFIG_DIR=/Users/eric/Arik/dev/synccenter-config

# Master bearer token. Generate with: openssl rand -hex 32
SC_API_TOKEN=replace-me-with-32-bytes-of-randomness

# Port the API listens on. Behind Traefik this is whatever the container exposes.
PORT=3000

# SQLite database path. Use :memory: for tests.
SC_DB_PATH=/var/lib/synccenter/state.sqlite

# Per-host Syncthing API keys.
# Variable name convention: SC_HOST_API_KEY_<NAME-IN-SHOUT-SNAKE>
# Example: a host named "mac-studio" -> SC_HOST_API_KEY_MAC_STUDIO
# These will be replaced by sops-decrypted material in Phase 5.
SC_HOST_API_KEY_MAC_STUDIO=
SC_HOST_API_KEY_QNAP_TS453D=
SC_HOST_API_KEY_WIN_DESKTOP=

# rclone rcd configuration. Leave SC_RCLONE_URL blank to disable the rclone routes.
# Use either user/pass (Basic) OR bearer (Token) — not both.
SC_RCLONE_URL=http://127.0.0.1:5572
SC_RCLONE_USER=
SC_RCLONE_PASS=
SC_RCLONE_BEARER=
